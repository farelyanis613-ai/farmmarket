## Configuration SMTP pour PHPMailer - Gmail
## Copiez ce fichier en ".env" et remplissez avec vos identifiants
## NE COMMITEZ PAS le .env réel en production !

# Serveur SMTP (Gmail)
MAIL_HOST=smtp.gmail.com

# Port TLS (recommandé)
MAIL_PORT=587

# Votre adresse Gmail
MAIL_USERNAME=votre-email@gmail.com

# App Password (16 caractères, depuis https://myaccount.google.com/apppasswords)
# IMPORTANT: Utilisez le mot de passe d'APPLICATION, pas votre mot de passe Gmail !
MAIL_PASSWORD=xxxx xxxx xxxx xxxx

# Adresse d'expédition (généralement pareil que MAIL_USERNAME)
MAIL_FROM_EMAIL=votre-email@gmail.com

# Nom affiché dans "De"
MAIL_FROM_NAME=FarmMarket

# Chiffrement (ne changez pas)
MAIL_ENCRYPTION=tls

# Authentification (ne changez pas)
MAIL_USE_AUTH=true

# Debug mode (0=désactivé, 2=verbose)
MAIL_DEBUG=0
